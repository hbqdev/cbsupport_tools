# Couchbase Support Tools Environment Configuration
# Copy this file to .env and customize for your machine

# Base directory where ticket directories are created
# Each ticket gets a subdirectory: $DIR_TICKETS/<ticket_number>/
# Examples:
#   macOS:   /Users/username/Downloads/couchbaselogs/support
#   Linux:   /home/username/couchbaselogs/support
#   Windows: /mnt/d/couchbaselogs/support
DIR_TICKETS="/path/to/your/couchbaselogs/support"

# Base directory for extract_ticket_timeline.sh (uses BASE_DIR variable)
# Should typically be the same as DIR_TICKETS
BASE_DIR="/path/to/your/couchbaselogs/support"

# AWS profile used by s3dl and aws-cli for downloading ticket files
# Uncomment and modify if you need a different profile than 'supportal'
# AWS_DEFAULT_PROFILE="supportal"
# S3DL_DEFAULT_PROFILE="supportal"
# BOTO_PROFILE="supportal"
# AWS_PROFILE="supportal"

# Log file for download progress messages (set to /dev/null to suppress)
# PREP_TICKET_LOG="/dev/null"
# EXTRACT_TICKET_LOG="/dev/null"
